---
source: lib/src/complete/fish.rs
expression: "complete_fish_init(\"usage\")"
---
# @generated by usage-cli — auto-completion for usage shebang scripts
# Source this file from ~/.config/fish/conf.d/ (or your fish config) to enable
# <Tab> completion for any command on $PATH whose first line is a `usage`
# shebang.

function __usage_register_shebang_completions
    if not type -q usage
        return 0
    end
    set -l registered
    for dir in $PATH
        test -d $dir; or continue
        for file in $dir/*
            test -f $file -a -x $file; or continue
            set -l name (path basename $file)
            contains -- $name $registered; and continue
            set -l first
            read -l first <$file 2>/dev/null
            if string match -q -- '#!*usage*' "$first"
                complete -c $name -x -a "(command usage complete-word --shell fish -f \"$file\" -- (commandline -opc) (commandline -t))"
                set -a registered $name
            end
        end
    end
end

__usage_register_shebang_completions
