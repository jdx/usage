---
source: lib/src/complete/bash.rs
expression: "complete_bash_init(\"usage\")"
---
# @generated by usage-cli — auto-completion for usage shebang scripts
# Source this file from your bashrc to enable <Tab> completion for any command
# on $PATH whose first line is a `usage` shebang.

_usage_default_complete() {
    local cmd="${COMP_WORDS[0]}"
    local cmdpath
    if [[ "$cmd" == */* ]]; then
        cmdpath="$cmd"
    else
        cmdpath="$(type -P "$cmd" 2>/dev/null)"
    fi

    if [[ -n "$cmdpath" && -f "$cmdpath" ]]; then
        local first
        if IFS= read -r first < "$cmdpath" 2>/dev/null && [[ "$first" == "#!"*"usage"* ]]; then
            if type -p usage &> /dev/null; then
                local IFS=$'\n'
                # shellcheck disable=SC2207
                COMPREPLY=( $(command usage complete-word --shell bash -f "$cmdpath" --cword="$COMP_CWORD" -- "${COMP_WORDS[@]}") )
                return 0
            fi
        fi
    fi

    # Not a usage shebang script — chain to bash-completion's loader if present
    if declare -F _completion_loader >/dev/null 2>&1; then
        _completion_loader "$@"
        return $?
    fi
    return 1
}

complete -D -F _usage_default_complete -o bashdefault -o default
