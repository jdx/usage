import { CliRunner, CliResult } from "./runtime";
import { AppFlags } from "./types";

export class App {
  private runner: CliRunner;

  constructor(binPath?: string) {
    this.runner = new CliRunner(binPath ?? "app");
  }
  /** [--dry-run] */
  exec(flags?: AppFlags): CliResult {
    const cmdArgs: string[] = [];
    const flagArgs = this.buildFlagArgs(flags);
    return this.runner.run([...cmdArgs, ...flagArgs]);
  }

  private buildFlagArgs(flags?: AppFlags): string[] {
    const result: string[] = [];
    if (!flags) return result;
    if (flags.dryRun) { result.push("--dry-run"); }
    else if (flags.dryRun === false) { result.push("--no-dry-run"); }
    return result;
  }
}
