//! @generated by usage-cli from test.usage.kdl. Do not edit manually.

use crate::runtime::{CliRunner, CliResult, CliError};
use crate::types::*;

#[derive(Debug, Clone)]
pub struct App {
    runner: CliRunner,
}

impl App {
    pub fn new(bin_path: &str) -> Self {
        Self::with_runner(CliRunner::new(bin_path))
    }

    pub fn with_runner(runner: CliRunner) -> Self {
        Self {
            runner: runner.clone(),
        }
    }

    /// [--dry-run]
    pub fn exec(&self, flags: Option<&AppFlags>) -> Result<CliResult, CliError> {
        let mut cmd_args: Vec<String> = vec![];
        cmd_args.extend(Self::build_flag_args(flags));
        self.runner.run(cmd_args)
    }

    fn build_flag_args(flags: Option<&AppFlags>) -> Vec<String> {
        let mut result = Vec::new();
        let Some(flags) = flags else { return result };
        if flags.dry_run == Some(true) {
            result.push("--dry-run".to_string());
        }
        else if flags.dry_run == Some(false) {
            result.push("--no-dry-run".to_string());
        }
        result
    }
}
