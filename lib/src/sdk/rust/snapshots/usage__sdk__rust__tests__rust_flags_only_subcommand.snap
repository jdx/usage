/// Show status
pub struct Status {
    runner: CliRunner,
}

impl Status {
    pub fn new(runner: CliRunner) -> Self {
        Self {
            runner,
        }
    }
    /// status [--verbose] [--json]

    pub fn exec(&self, flags: Option<StatusFlags>) -> Result<CliResult, crate::runtime::CliError> {
        let mut cmd_args: Vec<String> = vec!["status".to_string()];
        let flag_args = self.build_flag_args(flags);
        cmd_args.extend(flag_args);
        self.runner.run(cmd_args)
    }

    fn build_flag_args(&self, flags: Option<StatusFlags>) -> Vec<String> {
        let mut result = Vec::new();
        let flags = match flags { Some(f) => f, None => return result };
        if let Some(v) = flags.verbose { if v { result.push("--verbose".to_string()); } }
        if let Some(v) = flags.json { if v { result.push("--json".to_string()); } }
        result
    }
}
