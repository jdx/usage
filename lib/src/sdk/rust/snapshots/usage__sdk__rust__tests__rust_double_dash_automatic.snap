//! @generated by usage-cli from test.usage.kdl. Do not edit manually.

use crate::runtime::{CliRunner, CliResult, CliError};
use crate::types::*;

#[derive(Debug, Clone)]
pub struct Runner {
    runner: CliRunner,
    pub run: Run,
}

impl Runner {
    pub fn new(bin_path: &str) -> Self {
        Self::with_runner(CliRunner::new(bin_path))
    }

    pub fn with_runner(runner: CliRunner) -> Self {
        Self {
            runner: runner.clone(),
            run: Run::new(runner.clone()),
        }
    }

    /// [--verbose…] <input> <extra>… <SUBCOMMAND>
    pub fn exec(&self, args: RunnerArgs, flags: Option<&RunnerFlags>) -> Result<CliResult, CliError> {
        let mut cmd_args: Vec<String> = vec![];
        cmd_args.push(args.input.to_string());
        cmd_args.extend(args.extra.iter().map(|v| v.to_string()));
        // double_dash=automatic: "--" is implied after the first positional arg
        cmd_args.extend(Self::build_flag_args(flags));
        self.runner.run(cmd_args)
    }

    fn build_flag_args(flags: Option<&RunnerFlags>) -> Vec<String> {
        let mut result = Vec::new();
        let Some(flags) = flags else { return result };
        if let Some(v) = &flags.verbose {
            for item in v {
                if *item { result.push("--verbose".to_string()); }
            }
        }
        result
    }
}

/// Run a task
#[derive(Debug, Clone)]
pub struct Run {
    runner: CliRunner,
}

impl Run {
    pub(crate) fn new(runner: CliRunner) -> Self {
        Self {
            runner: runner.clone(),
        }
    }

    /// run <task>
    /// Basic run: `runner run hello`
    pub fn exec(&self, args: RunArgs) -> Result<CliResult, CliError> {
        let mut cmd_args: Vec<String> = vec!["run".to_string()];
        cmd_args.push(args.task.to_string());
        // double_dash=automatic: "--" is implied after the first positional arg
        self.runner.run(cmd_args)
    }
}
