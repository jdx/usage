/// Greet someone
pub struct Greet {
    runner: CliRunner,
}

impl Greet {
    pub fn new(runner: CliRunner) -> Self {
        Self {
            runner,
        }
    }
    /// greet <name>
    /// Example: app greet hello

    pub fn exec(&self, args: GreetArgs) -> Result<CliResult, crate::runtime::CliError> {
        let mut cmd_args: Vec<String> = vec!["greet".to_string()];
        cmd_args.push(args.name.to_string());
        self.runner.run(cmd_args)
    }
