/// Greet someone
#[derive(Debug, Clone)]
pub struct Greet {
    runner: CliRunner,
}

impl Greet {
    pub(crate) fn new(runner: CliRunner) -> Self {
        Self {
            runner: runner.clone(),
        }
    }

    /// greet <name>
    /// Example: `app greet hello`
    pub fn exec(&self, args: GreetArgs) -> Result<CliResult, CliError> {
        let mut cmd_args: Vec<String> = vec!["greet".to_string()];
        cmd_args.push(args.name.to_string());
        self.runner.run(cmd_args)
    }
}
